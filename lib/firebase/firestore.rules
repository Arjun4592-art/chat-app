rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isSelf(uid) { return isAuth() && request.auth.uid == uid; }

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    // ── Chats ─────────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      // Allow list/query for authenticated users (needed for array-contains queries)
      allow list:   if isAuth();
      allow get:    if isAuth() && request.auth.uid in resource.data.members;
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid in resource.data.members;
      allow delete: if false;

      // ── Messages ─────────────────────────────────────────────────────────────
      match /messages/{msgId} {
        allow read:   if isAuth() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        allow create: if isAuth()
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
                      && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuth()
                      && request.resource.data.senderId == request.auth.uid;
        allow delete: if false;
      }
    }

    // ── Invites ────────────────────────────────────────────────────────────────
    match /invites/{code} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // ── OTP codes — server only ────────────────────────────────────────────────
    match /otpCodes/{email} {
      allow read:   if false;
      allow write:  if false;
    }

    // ── Scheduled deletes — server only ───────────────────────────────────────
    match /scheduledDeletes/{uid} {
      allow read:   if false;
      allow write:  if false;
    }
  }
}
